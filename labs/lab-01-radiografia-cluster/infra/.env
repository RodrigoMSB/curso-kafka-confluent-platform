# ============================================================
# NovaTech Logistics - Lab 01: Radiografía de un clúster Kafka
# Variables de entorno para Docker Compose
# ============================================================

# Versiones de imágenes
# Para producción se recomienda pinear KAFBAT_UI_VERSION a un tag específico.
KAFKA_VERSION=8.2.0
KAFBAT_UI_VERSION=latest

# ID del clúster KRaft (base64, generado una vez)
CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# Puertos externos de los brokers
BROKER1_EXTERNAL_PORT=9092
BROKER2_EXTERNAL_PORT=9093
BROKER3_EXTERNAL_PORT=9094

# Puertos internos de los brokers (comunicación inter-broker)
BROKER1_INTERNAL_PORT=29092
BROKER2_INTERNAL_PORT=29093
BROKER3_INTERNAL_PORT=29094

# Puertos del listener CONTROLLER (quorum KRaft, dedicados)
BROKER1_CONTROLLER_PORT=39092
BROKER2_CONTROLLER_PORT=39093
BROKER3_CONTROLLER_PORT=39094

# Puerto de Kafbat UI en el HOST (interfaz web).
# Se eligió 8090 porque 8080 suele estar ocupado por otras herramientas
# de desarrollo (Tomcat, Spring Boot, Jenkins, etc.).
# Si tu máquina tiene 8090 ocupado, puedes cambiarlo a otro puerto libre.
KAFBAT_UI_PORT=8090

# Configuración del tópico principal
TOPIC_NAME=novatech.fleet.gps
PARTITIONS=6
REPLICATION_FACTOR=3
